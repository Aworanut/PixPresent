# =============================================================================
# PixPresent (FaceFind) — Environment Variables Template
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Local dev: values printed by `supabase start` (defaults below are the
# well-known local keys baked into the Supabase CLI — safe for local only).
# Production: fill from Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# AWS Rekognition (Face indexing & search)
# -----------------------------------------------------------------------------
# IAM user with `AmazonRekognitionFullAccess` (least-privilege; tighten later).
# Region: ap-southeast-1 (Singapore) recommended for Thailand latency.
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (Photo storage + CDN)
# -----------------------------------------------------------------------------
# Account ID: Cloudflare dashboard → R2 → Overview (right sidebar).
# Bucket name: created in #2 External Service Setup.
# Public URL: custom domain or `https://pub-<hash>.r2.dev` from R2 dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pixpresent-photos
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Google Drive (Photographer file source)
# -----------------------------------------------------------------------------
# OAuth 2.0 client (scope: drive.readonly).
# Redirect URI: http://localhost:3000/api/auth/google/callback (dev)
# Add exactly this URI in Google Cloud Console → Credentials → OAuth Client → Authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# Omise (Phase 2 placeholder — deferred per ISSUES.md #B-04)
# -----------------------------------------------------------------------------
# Phase 1 uses manual slip + credit ledger (#13). Leave blank until #B-04.
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# -----------------------------------------------------------------------------
# SlipOK — slip auto-verification (#13)
# -----------------------------------------------------------------------------
# Full endpoint URL จาก SlipOK dashboard
SLIPOK_API_URL=https://api.slipok.com/api/line/apikey/{YOUR_KEY}
# Bearer token (SLIP... key จาก dashboard) — optional แต่แนะนำสำหรับ production
SLIPOK_API_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@pixpresent.app

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Super admin emails (comma-separated) for admin panel access + notifications (#13, #19).
SUPER_ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cron jobs
# -----------------------------------------------------------------------------
# Secret token ที่ Vercel ส่งมาใน Authorization header ตอนเรียก cron endpoint.
# ตั้งค่าเดียวกันใน Vercel dashboard → Settings → Environment Variables.
# สำหรับ test manual: curl -H "Authorization: Bearer <value>" /api/cron/cleanup-collections
CRON_SECRET=

# ─── Finances dashboard (admin/finances) ─────────────────────────────────────
# อัตราแลกเปลี่ยน USD → THB สำหรับแสดงต้นทุน AWS (default 35)
USD_TO_THB=35
# Fixed costs รายเดือน — ถ้าไม่ตั้งค่า จะแสดงเป็น ฿0
SUPABASE_MONTHLY_COST_USD=0
RESEND_MONTHLY_COST_USD=0
SLIPOK_MONTHLY_COST_THB=0
OTHER_MONTHLY_COST_THB=0

# Dropbox (storage source — optional; stubs when absent)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:3000/api/auth/dropbox/callback
